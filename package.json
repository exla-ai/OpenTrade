    "lint": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "typescript": "5.9.2"
  },
  "trustedDependencies": ["better-sqlite3", "electron", "esbuild", "node-pty"]
}
