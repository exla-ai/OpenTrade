{
  "name": "opentrade",
  "version": "0.0.0",
  "private": true,
  "license": "Elastic-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": ["app"],
  "scripts": {
    "dev": "bun run --cwd app dev",
    "build": "bun run --cwd app build",
    "typecheck": "bun run --cwd app typecheck",
