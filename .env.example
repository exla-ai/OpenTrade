# macOS code-signing + notarization credentials for LOCAL signed builds.
#
# These are BUILD-TIME ONLY — consumed by electron-builder when you run
# `bun run --cwd app package:signed`. The OpenTrade app itself never reads them.
# For CI / public releases, set these as GitHub Actions repo secrets instead
# (Settings -> Secrets and variables -> Actions); do NOT rely on this file in CI.
#
# Copy to `.env` (gitignored) and fill in. NEVER commit the real `.env` or the .p12.
# See docs/PACKAGING.md for how to obtain each value.

# Your "Developer ID Application" certificate. LOCALLY this can just be an absolute
# path to the .p12 (e.g. /Users/you/certs/DeveloperID.p12 or $HOME/certs/cert.p12).
# In CI use the base64 of the file instead (base64 -i cert.p12 | pbcopy), since the
# runner has no local file.
CSC_LINK=
# The password you set when exporting the .p12 from Keychain Access
CSC_KEY_PASSWORD=
# Apple ID email on the developer account (for notarization)
APPLE_ID=
# App-specific password from appleid.apple.com (xxxx-xxxx-xxxx-xxxx)
APPLE_APP_SPECIFIC_PASSWORD=
# 10-character Apple Developer Team ID
APPLE_TEAM_ID=
